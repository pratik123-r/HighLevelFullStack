{
  "name": "event-booking-system",
  "version": "1.0.0",
  "description": "Event Booking System with PostgreSQL and MongoDB Audit Logs",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "worker:seat": "node src/workers/seatGenerationWorkerEntry.js",
    "worker:audit": "node src/workers/auditLogWorkerEntry.js",
    "worker:seat:watch": "node --watch src/workers/seatGenerationWorkerEntry.js",
    "worker:audit:watch": "node --watch src/workers/auditLogWorkerEntry.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .js"
  },
  "keywords": ["event-booking", "postgresql", "mongodb", "bullmq"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "prisma": "^5.7.1"
  }
}
