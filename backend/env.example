# ============================================
# Event Booking System - Environment Variables
# ============================================
# Copy this file to .env and update with your actual values
# cp env.example .env

# ============================================
# Server Configuration
# ============================================
# Port on which the API server will run
PORT=3000

# Application environment: development, production, test
NODE_ENV=development

# ============================================
# PostgreSQL Database (Core Data)
# ============================================
# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://postgres:password@localhost:5432/event_booking?schema=public
DATABASE_URL="postgresql://postgres:pratik@localhost:5432/event_booking?schema=public"

# ============================================
# MongoDB Database (Audit Logs Only)
# ============================================
# MongoDB connection string for audit logs
# Format: mongodb://USER:PASSWORD@HOST:PORT/DATABASE
# Example: mongodb://localhost:27017/event_booking_audit
# For MongoDB Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE
MONGODB_URI="mongodb://localhost:27017/event_booking_audit"

# ============================================
# Redis Configuration (BullMQ Queue)
# ============================================
# Redis host address
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (leave empty if no password is set)
REDIS_PASSWORD=

# ============================================
# Optional: Advanced Configuration
# ============================================
# Uncomment and configure if needed:

# Redis connection string (alternative to individual settings above)
# REDIS_URL=redis://localhost:6379

# Database connection pool size (Prisma)
# DATABASE_POOL_SIZE=10

# MongoDB connection options (if needed)
# MONGODB_OPTIONS='{"maxPoolSize":10}'

# ============================================
# Production Notes
# ============================================
# For production:
# 1. Set NODE_ENV=production
# 2. Use strong passwords for all databases
# 3. Use connection pooling for high traffic
# 4. Enable SSL/TLS for database connections
# 5. Store sensitive values in secure secret management
# 6. Never commit .env file to version control

