                      "if (pm.response.code === 200) {",
                      "    var jsonData = pm.response.json();",
                      "    if (jsonData.data && jsonData.data.length > 0) {",
                      "        pm.environment.set('seat_id', jsonData.data[0].id);",
                      "        pm.environment.set('seat_id_2', jsonData.data.length > 1 ? jsonData.data[1].id : jsonData.data[0].id);",
