# ============================================
# Event Booking System - Frontend Environment Variables
# ============================================
# Copy this file to .env and update with your actual values
# cp env.example .env

# ============================================
# Server Configuration
# ============================================
# Port on which the frontend dev server will run
# Default: 5173
VITE_PORT=5173

# ============================================
# API Configuration
# ============================================
# Backend API base URL
# For local development: http://localhost:3000
# For production: https://your-api-domain.com
VITE_API_URL=http://localhost:3000

# ============================================
# Production Notes
# ============================================
# For production:
# 1. Update VITE_API_URL to your production API URL
# 2. Ensure CORS is properly configured on the backend
# 3. Never commit .env file to version control
# 4. Vite requires VITE_ prefix for environment variables to be exposed to the client

